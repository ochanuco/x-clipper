{
  "name": "x-clipper",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build:icons": "node scripts/convert-icons.mjs",
    "build": "pnpm run build:icons && MANIFEST_ENV=local node esbuild.mjs",
    "build:dev": "pnpm run build:icons && MANIFEST_ENV=dev node esbuild.mjs",
    "build:prod": "pnpm run build:icons && MANIFEST_ENV=prod node esbuild.mjs",
    "version:bump:patch": "node scripts/bump-version.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:e2e": "node scripts/run-e2e.mjs"
  },
  "dependencies": {
    "@notionhq/client": "^5.0.0",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.0.269",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.19.25",
    "esbuild": "^0.27.0",
    "jsdom": "^29.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
